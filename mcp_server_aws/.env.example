AWS_MCP_ENDPOINT=https://aws-mcp.us-east-1.api.aws/mcp
AWS_MCP_REGION=us-east-1
# AWS_MCP_SERVICE=            # leave unset to auto-infer from URL
AWS_ROLE_NAME=McpExecutionRole
# AWS_BOOTSTRAP_PROFILE=      # leave unset to use instance role (ECS/AgentCore)
STS_REFRESH_WINDOW_SECONDS=300
WRAPPER_HOST=0.0.0.0
WRAPPER_PORT=8000
WRAPPER_LOG_LEVEL=INFO
